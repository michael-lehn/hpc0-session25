#!/usr/bin/env bash

set -e

compiler=xtest_abc_simple
assembler=ulmas_simple
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage()
{
    cat >&2 <<EOF
Usage:
    myabc_simple [-S] [-o output] file.abc
    myabc_simple file.abc [-S] [-o output]

Options:
    -S          Generate assembly only
    -o output   Name of the executable
EOF
    exit 1
}

assemble_only=false
output=
input=

while (($# > 0)); do
    case $1 in
        -S)
            assemble_only=true
            shift
            ;;

        -o)
            (($# >= 2)) || usage
            output=$2
            shift 2
            ;;

        -h|--help)
            usage
            ;;

        -*)
            echo "myabc_simple: unknown option '$1'" >&2
            usage
            ;;

        *)
            if [[ -n $input ]]; then
                echo "myabc_simple: more than one input file specified" >&2
                usage
            fi
            input=$1
            shift
            ;;
    esac
done

[[ -n $input ]] || usage

[[ -f $input ]] || {
    echo "myabc_simple: input file '$input' not found" >&2
    exit 1
}

case $input in
    *.abc)
        ;;
    *)
        echo "myabc_simple: input file must have the extension '.abc'" >&2
        exit 1
        ;;
esac

source_dir=$(dirname -- "$input")
source_name=$(basename -- "$input")
base_name=${source_name%.abc}
asm_file="$base_name.s"

if $assemble_only; then
    if [[ -n $output ]]; then
        echo "myabc_simple: options '-S' and '-o' cannot be used together" >&2
	echo "" >&2
	usage
        exit 1
    fi

    "$compiler" < "$input" > "$asm_file"
    exit
fi

tmp_asm=$(mktemp "${TMPDIR:-/tmp}/myabc.XXXXXXXX")
tmp_aout=$(mktemp "${TMPDIR:-/tmp}/myabc.XXXXXXXX")
trap 'rm -f "$tmp_asm" "$tmp_aout"' EXIT

"$compiler" < "$input" > "$tmp_asm"

if [[ -n $output ]]; then

    "$assembler" -o "$tmp_aout" "$tmp_asm"
    (echo "#! $script_dir/ulm_simple"; cat "$tmp_aout") > "$output"
    chmod +x "$output"
else
    "$assembler" -o "$tmp_aout" "$tmp_asm"
    (echo "#! $script_dir/ulm_simple"; cat "$tmp_aout") > a.out
    chmod +x a.out
fi
